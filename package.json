{
  "name": "gothic-lockpick-solver",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint",
    "format": "oxfmt && prettier --write \"src/**/*.svelte\"",
    "format:check": "oxfmt --check && prettier --check \"src/**/*.svelte\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --project unit --passWithNoTests"
  },
  "devDependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@inlang/paraglide-js": "^2.20.2",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^26.1.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.2.0",
    "wrangler": "^4.107.0"
  }
}
